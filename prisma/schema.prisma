// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── User / Account ───────────────────────────────────────────────────────────

model User {
  username  String   @id
  password  String
  role      String   @default("admin")
  branch    String
  createdAt DateTime @default(now())

  @@map("users")
}

// ─── Branch ───────────────────────────────────────────────────────────────────

model Branch {
  id   String @id
  name String @unique

  @@map("branches")
}

// ─── Category ─────────────────────────────────────────────────────────────────

model Category {
  id   String @id @default(cuid())
  name String @unique

  @@map("categories")
}

// ─── Product ──────────────────────────────────────────────────────────────────

model Product {
  id           String  @id
  name         String
  categoryName String
  price        Decimal @db.Decimal(15, 2)
  branch       String

  stockItems      StockItem[]
  orderItems      OrderItem[]
  scheduledPrices ScheduledPrice[]

  @@map("products")
}

// ─── ScheduledPrice ───────────────────────────────────────────────────────────

model ScheduledPrice {
  id        String   @id @default(cuid())
  productId String
  newPrice  Decimal  @db.Decimal(15, 2)
  startDate DateTime @db.Date

  product Product @relation(fields: [productId], references: [id])

  @@map("scheduled_prices")
}

// ─── Store ────────────────────────────────────────────────────────────────────

model Store {
  id     String @id
  name   String
  branch String

  orders      Order[]
  receivables Receivable[]

  @@map("stores")
}

// ─── Order ────────────────────────────────────────────────────────────────────

model Order {
  id        String   @id
  storeId   String
  branch    String
  total     Decimal  @db.Decimal(15, 2)
  createdAt DateTime

  store       Store        @relation(fields: [storeId], references: [id])
  items       OrderItem[]
  receivables Receivable[]

  @@map("orders")
}

model OrderItem {
  id          String  @id @default(cuid())
  orderId     String
  productId   String
  productName String
  quantity    Int
  price       Decimal @db.Decimal(15, 2)

  order   Order   @relation(fields: [orderId], references: [id])
  product Product @relation(fields: [productId], references: [id])

  @@map("order_items")
}

// ─── Receivable ───────────────────────────────────────────────────────────────

model Receivable {
  id      String   @id @default(cuid())
  storeId String
  orderId String
  amount  Decimal  @db.Decimal(15, 2)
  dueDate DateTime
  isPaid  Boolean  @default(false)

  store Store @relation(fields: [storeId], references: [id])
  order Order @relation(fields: [orderId], references: [id])

  @@map("receivables")
}

// ─── Stock ────────────────────────────────────────────────────────────────────

model StockItem {
  id        String @id @default(cuid())
  productId String
  branch    String
  totalIn   Int    @default(0)
  totalOut  Int    @default(0)

  product Product @relation(fields: [productId], references: [id])

  @@unique([productId, branch])
  @@map("stock_items")
}
